{
  "$schema": "https://opencode.ai/config.json",
  "model": "YOUR_MODEL_HERE",
  "small_model": "YOUR_MODEL_HERE",
  "default_agent": "build",
  "permission": {
    "lsp": "allow"
  },
  "lsp": {
    "jdtls": {
      "command": ["jdtls"],
      "extensions": [".java"],
      "env": {
        "JAVA_HOME": "${JAVA_HOME}"
      }
    }
  },
  "skills": {
    "sop-code-review": ".claude/skills/sop-code-review/SKILL.md",
    "sop-prd": ".claude/skills/sop-prd/SKILL.md",
    "sop-testing": ".claude/skills/sop-testing/SKILL.md",
    "sop-bug-fix": ".claude/skills/sop-bug-fix/SKILL.md",
    "sop-deployment": ".claude/skills/sop-deployment/SKILL.md",
    "sop-scaffold": ".claude/skills/sop-scaffold/SKILL.md",
    "sop-backend-iteration": ".claude/skills/sop-backend-iteration/SKILL.md",
    "sop-frontend-iteration": ".claude/skills/sop-frontend-iteration/SKILL.md",
    "sop-fullstack-iteration": ".claude/skills/sop-fullstack-iteration/SKILL.md",
    "sop-dependency-analysis": ".claude/skills/sop-dependency-analysis/SKILL.md",
    "sop-knowledge": ".claude/skills/sop-knowledge/SKILL.md",
    "sop-library-research": ".claude/skills/sop-library-research/SKILL.md",
    "sop-incident-response": ".claude/skills/sop-incident-response/SKILL.md",
    "sop-onboarding": ".claude/skills/sop-onboarding/SKILL.md",
    "sop-product-analysis": ".claude/skills/sop-product-analysis/SKILL.md",
    "sop-api-design": ".claude/skills/sop-api-design/SKILL.md",
    "sop-database-design": ".claude/skills/sop-database-design/SKILL.md",
    "SOP": ".claude/skills/SOP.md",
    "dr-jskill": ".claude/skills/dr-jskill/SKILL.md",
    "frontend-design": ".claude/skills/frontend-design/SKILL.md"
  },
  "instructions": [
    "AGENTS.md",
    ".claude/agents/code-reviewer.md",
    ".claude/agents/java-reviewer.md",
    ".claude/agents/security-reviewer.md",
    ".claude/agents/build-error-resolver.md",
    ".claude/rules/common/01_naming.md",
    ".claude/rules/common/02_oop.md",
    ".claude/rules/common/03_concurrency.md",
    ".claude/rules/common/04_control.md",
    ".claude/rules/common/05_exception.md",
    ".claude/rules/common/06_logging.md",
    ".claude/rules/common/07_testing.md",
    ".claude/rules/common/08_security.md",
    ".claude/rules/common/09_project.md",
    ".claude/rules/common/10_mysql.md",
    ".claude/skills/dr-jskill/references/DATABASE.md",
    ".claude/skills/dr-jskill/references/SECURITY.md",
    ".claude/skills/dr-jskill/references/TEST.md",
    ".claude/skills/dr-jskill/references/CONFIGURATION.md",
    ".claude/skills/dr-jskill/references/LOGGING.md",
    ".claude/skills/dr-jskill/references/PROJECT-SETUP.md",
    ".claude/skills/dr-jskill/references/SPRING-BOOT-4.md",
    ".claude/skills/dr-jskill/references/DOCKER.md",
    ".claude/skills/dr-jskill/references/JDTLS.md",
    ".claude/skills/dr-jskill/references/MYBATIS-PLUS.md",
    ".claude/skills/dr-jskill/references/VUE.md",
    ".claude/skills/dr-jskill/references/REACT.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "agent": {
    "build": {
      "description": "Primary coding agent for project development",
      "mode": "primary",
      "model": "YOUR_MODEL_HERE",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "task": true
      }
    },
    "java-reviewer": {
      "description": "Expert Java and Spring Boot code reviewer specializing in layered architecture, JPA patterns, security, and concurrency.",
      "mode": "subagent",
      "model": "YOUR_MODEL_HERE",
      "prompt": "You are an expert Java and Spring Boot code reviewer specializing in layered architecture, JPA patterns, security, and concurrency. Use for all code changes. MUST BE USED for Spring Boot projects.",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "code-reviewer": {
      "description": "Expert code review specialist. Reviews code for quality, security, and maintainability. Use immediately after writing or modifying code.",
      "mode": "subagent",
      "model": "YOUR_MODEL_HERE",
      "prompt": "You are an expert code reviewer ensuring high standards of code quality and security.",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "security-reviewer": {
      "description": "Security vulnerability detection and remediation specialist. Use for security issues.",
      "mode": "subagent",
      "model": "YOUR_MODEL_HERE",
      "prompt": "You are an expert security specialist focused on identifying and remediating vulnerabilities in web applications.",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "search-first": {
      "description": "Research and code search specialist",
      "mode": "subagent",
      "model": "YOUR_MODEL_HERE",
      "prompt": "You are a research specialist. Search for relevant code and documentation before making changes.",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    }
  },
  "command": {
    "sop prd": {
      "description": "Generate PRD product requirements document",
      "agent": "build",
      "template": "Please execute the PRD generation SOP workflow.\n\n$ARGUMENTS"
    },
    "sop testing": {
      "description": "Execute standard testing workflow",
      "agent": "build",
      "template": "Please execute the testing SOP workflow for this project.\n\n$ARGUMENTS"
    },
    "sop bug-fix": {
      "description": "Execute bug fix workflow with parallel agents",
      "agent": "build",
      "template": "Please execute the bug fix SOP workflow.\n\n$ARGUMENTS"
    },
    "sop code-review": {
      "description": "Execute code review workflow",
      "agent": "java-reviewer",
      "template": "Please execute the code review SOP workflow.\n\n$ARGUMENTS"
    },
    "sop deployment": {
      "description": "Execute deployment workflow",
      "agent": "build",
      "template": "Please execute the deployment SOP workflow.\n\n$ARGUMENTS"
    },
    "sop scaffold": {
      "description": "Initialize new project scaffold",
      "agent": "build",
      "template": "Please execute the scaffold SOP workflow.\n\n$ARGUMENTS"
    },
    "sop backend": {
      "description": "Backend-only iteration workflow",
      "agent": "build",
      "template": "Please execute the backend iteration SOP workflow.\n\n$ARGUMENTS"
    },
    "sop frontend": {
      "description": "Frontend-only iteration workflow",
      "agent": "build",
      "template": "Please execute the frontend iteration SOP workflow.\n\n$ARGUMENTS"
    },
    "sop fullstack": {
      "description": "Fullstack iteration workflow (backend + frontend)",
      "agent": "build",
      "template": "Please execute the fullstack iteration SOP workflow.\n\n$ARGUMENTS"
    },
    "sop dependency-analysis": {
      "description": "Dependency and conflict analysis using Graphify",
      "agent": "build",
      "template": "Execute dependency analysis SOP.\n\n$ARGUMENTS"
    },
    "java-review": {
      "description": "Review Java code using java-reviewer agent",
      "agent": "java-reviewer",
      "template": "Please review the Java code at the following path:\n$ARGUMENTS"
    },
    "code-review": {
      "description": "Review code using code-reviewer agent",
      "agent": "code-reviewer",
      "template": "Please review the code at the following path:\n$ARGUMENTS"
    },
    "security-review": {
      "description": "Review security using security-reviewer agent",
      "agent": "security-reviewer",
      "template": "Please perform security review at the following path:\n$ARGUMENTS"
    },
    "graphify": {
      "description": "Build knowledge graph with Graphify",
      "agent": "build",
      "template": "Build knowledge graph using Graphify.\n\n$ARGUMENTS"
    },
    "graphify query": {
      "description": "Query Graphify knowledge graph",
      "agent": "build",
      "template": "Query Graphify knowledge graph.\n\nQuery: $ARGUMENTS"
    },
    "sop status": {
      "description": "Show status of all SOP tasks",
      "agent": "build",
      "template": "Show the status of all in-progress and recently completed SOP tasks.\n\n$ARGUMENTS"
    }
  },
  "plugin": [
    ".opencode/plugins/graphify.js"
  ]
}